{
  "name": "@mdpact/cli",
  "version": "0.1.0",
  "description": "mdpact CLI — lint, test, and score agent instruction files",
  "type": "module",
  "bin": {
    "mdpact": "./bin/mdpact.mjs"
  },
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "files": ["bin", "dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@mdpact/config": "workspace:*",
    "@mdpact/core": "workspace:*",
    "@mdpact/engine": "workspace:*",
    "@mdpact/rules": "workspace:*",
    "citty": "^0.1.6",
    "cli-table3": "^0.6.5",
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.10"
  },
  "devDependencies": {
    "@types/node": "^20.17.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
