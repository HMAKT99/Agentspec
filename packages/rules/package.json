{
  "name": "@mdpact/rules",
  "version": "0.0.1",
  "description": "Built-in rule definitions for mdpact",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@mdpact/core": "workspace:*",
    "mdast-util-to-string": "^4.0.0",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.17.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
